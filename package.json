{
    "name": "stromanalytics",
    "version": "2.0.0",
    "description": "StromAnalytics — The Analyst's Terminal",
    "private": true,
    "engines": {
        "node": ">=20"
    },
    "scripts": {
        "dev": "concurrently --names \"UI,API\" -c \"cyan.bold,green.bold\" --kill-others-on-fail \"npm run dev --prefix frontend\" \"node backend/server.js\"",
        "build": "npm run build --prefix frontend",
        "preview": "npm run preview --prefix frontend",
        "postinstall": "npm install --prefix frontend && npm install --prefix backend"
    },
    "dependencies": {
        "cors": "^2.8.5",
        "express": "^4.18.2",
        "yahoo-finance2": "^2.11.3"
    },
    "devDependencies": {
        "concurrently": "^8.2.2"
    }
}